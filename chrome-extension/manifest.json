{
  "manifest_version": 3,
  "name": "Privacy Shield - AI Text Cleaner",
  "version": "1.0.0",
  "description": "Clean PII from any text with one click. Uses local AI to remove names, emails, phones, addresses instantly.",
  "permissions": ["activeTab", "storage", "contextMenus"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["popup.css"]
  }],
  "action": { "default_popup": "popup.html", "default_icon": "icon.png" },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "host_permissions": ["<all_urls>"]
}